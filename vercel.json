{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @ikhora/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/web/.next",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/web packages/shared packages/database",
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://ikhora-fluent.vercel.app"
  }
}
